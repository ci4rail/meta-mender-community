From 20017c5aa4a3f0a79eec2f795dfa577a8ba317d0 Mon Sep 17 00:00:00 2001
From: kas User <kas@example.com>
Date: Thu, 17 Apr 2025 14:13:48 +0000
Subject: [PATCH] configs: verdin-imx8mp: mender integration

---
 configs/verdin-imx8mp_defconfig | 4 ++++
 include/configs/verdin-imx8mp.h | 3 +++
 2 files changed, 7 insertions(+)

diff --git a/configs/verdin-imx8mp_defconfig b/configs/verdin-imx8mp_defconfig
index ded9e19bcca..063b530393b 100644
--- a/configs/verdin-imx8mp_defconfig
+++ b/configs/verdin-imx8mp_defconfig
@@ -7,6 +7,8 @@ CONFIG_SPL_LIBGENERIC_SUPPORT=y
 CONFIG_NR_DRAM_BANKS=2
 CONFIG_ENV_SIZE=0x2000
 CONFIG_ENV_OFFSET=0xFFFFDE00
+CONFIG_ENV_OFFSET_REDUND=0xFFFFBE00
+CONFIG_SYS_REDUNDAND_ENVIRONMENT=y
 CONFIG_SYS_I2C_MXC_I2C1=y
 CONFIG_SYS_I2C_MXC_I2C2=y
 CONFIG_SYS_I2C_MXC_I2C3=y
@@ -98,6 +100,8 @@
 CONFIG_SYS_RELOC_GD_ENV_ADDR=y
 CONFIG_SYS_MMC_ENV_DEV=2
 CONFIG_SYS_MMC_ENV_PART=1
+CONFIG_USE_BOOTCOMMAND=y
+CONFIG_BOOTCOMMAND="run mender_setup; part uuid mmc 2:${mender_boot_part_hex} mender_root_uuid; setenv bootargs ro rootwait root=PARTUUID=${mender_root_uuid}; if test ${mender_boot_part} = 2; then setenv mender_bootfit_name fitImage-A; elif test ${mender_boot_part} = 3; then setenv mender_bootfit_name fitImage-B; else echo Invalid Mender boot slot ${mender_boot_part}; reset; fi; setenv mender_bootfit_conf; if test -n \"${mender_secboot_overlay}\"; then setenv mender_bootfit_conf conf-freescale_${mender_dtb_name}#conf-${mender_secboot_overlay}; fi; if load mmc 2:1 ${ramdisk_addr_r} /${mender_bootfit_name}; then if test -n \"${mender_bootfit_conf}\"; then bootm ${ramdisk_addr_r}#${mender_bootfit_conf}; else bootm ${ramdisk_addr_r}; fi; fi; run mender_try_to_recover"
 CONFIG_ENV_VARS_UBOOT_RUNTIME_CONFIG=y
 CONFIG_USE_ETHPRIME=y
 CONFIG_ETHPRIME="eth0"
diff --git a/include/configs/verdin-imx8mp.h b/include/configs/verdin-imx8mp.h
index 0b88e95603d..a3cbdf8af3b 100644
--- a/include/configs/verdin-imx8mp.h
+++ b/include/configs/verdin-imx8mp.h
@@ -53,6 +53,9 @@
 #define CFG_SYS_INIT_RAM_ADDR	0x40000000
 #define CFG_SYS_INIT_RAM_SIZE	SZ_512K
 
+#define CONFIG_BOOTCOUNT_ENV
+#define CONFIG_BOOTCOUNT_LIMIT
+
 /* i.MX 8M Plus supports max. 8GB memory in two albeit concecutive banks */
 #define CFG_SYS_SDRAM_BASE		0x40000000
 #define PHYS_SDRAM			0x40000000
